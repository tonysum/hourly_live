# 数据库配置（可选 — 不配则自动使用 SQLite）
# HOURLY_DB=sqlite          # 或 postgres
# HOURLY_DB_PATH=data/hourly_paper.db  # SQLite 路径

# PostgreSQL（仅 HOURLY_DB=postgres 时需要）
# PG_HOST=192.168.2.250
# PG_PORT=5432
# PG_DB=crypto_data
# PG_USER=crypto_user
# PG_PASSWORD=your_password

# coins.json 路径（可选 — 默认使用包内自带的）
# COINS_JSON_PATH=/path/to/coins.json
